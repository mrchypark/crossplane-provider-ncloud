+func isSESG3Create(d *schema.ResourceData, managerNode, dataNode map[string]interface{}, masterNodeProductCode *string) bool {
+	if strings.Contains(d.Get("os_image_code").(string), ".G003") ||
+		strings.Contains(managerNode["product_code"].(string), ".G003") ||
+		strings.Contains(dataNode["product_code"].(string), ".G003") {
+		return true
+	}
+	return masterNodeProductCode != nil && strings.Contains(*masterNodeProductCode, ".G003")
+}
+
+func createSESG3Cluster(ctx context.Context, config *conn.ProviderConfig, d *schema.ResourceData, searchEngine, managerNode, dataNode map[string]interface{}, isMasterOnlyNodeActivated bool, masterNodeProductCode *string, masterNodeSubnetNo *int32, masterNodeCount *int32) (string, error) {
+	req := map[string]any{
+		"clusterName":                                *StringPtrOrNil(d.GetOk("cluster_name")),
+		"searchEngineVersionCode":                    *StringPtrOrNil(searchEngine["version_code"], true),
+		"searchEngineUserName":                       *StringPtrOrNil(searchEngine["user_name"], true),
+		"searchEngineUserPassword":                   *StringPtrOrNil(searchEngine["user_password"], true),
+		"searchEngineDashboardPort":                  *StringPtrOrNil(searchEngine["dashboard_port"], true),
+		"softwareProductCode":                        *StringPtrOrNil(d.GetOk("os_image_code")),
+		"vpcNo":                                      *Int32PtrOrNil(d.GetOk("vpc_no")),
+		"hypervisorCode":                             "KVM",
+		"generationCode":                             "G3",
+		"isDualManager":                              *BoolPtrOrNil(managerNode["is_dual_manager"], true),
+		"managerNodeSubnetNo":                        *Int32PtrOrNil(managerNode["subnet_no"], true),
+		"managerNodeProductCode":                     *StringPtrOrNil(managerNode["product_code"], true),
+		"dataNodeSubnetNo":                           *Int32PtrOrNil(dataNode["subnet_no"], true),
+		"dataNodeCount":                              *Int32PtrOrNil(dataNode["count"], true),
+		"dataNodeProductCode":                        *StringPtrOrNil(dataNode["product_code"], true),
+		"dataNodeStorageSize":                        *Int32PtrOrNil(dataNode["storage_size"], true),
+		"dataNodeStorageInfraResourceDetailTypeCode": "CB1",
+		"serverSpecCode":                             sesServerSpecCodeFromProduct(*StringPtrOrNil(dataNode["product_code"], true)),
+		"isMasterOnlyNodeActivated":                  isMasterOnlyNodeActivated,
+		"loginKeyName":                               *StringPtrOrNil(d.GetOk("login_key_name")),
+	}
+	if isMasterOnlyNodeActivated {
+		req["masterNodeProductCode"] = *masterNodeProductCode
+		req["masterNodeSubnetNo"] = *masterNodeSubnetNo
+		req["masterNodeCount"] = *masterNodeCount
+	}
+
+	var createResp struct {
+		Code    int    `json:"code"`
+		Message string `json:"message"`
+		Result  struct {
+			ServiceGroupInstanceNo int32 `json:"serviceGroupInstanceNo"`
+		} `json:"result"`
+	}
+	if err := config.RawJSONRequest(ctx, "ses", "POST", "/api/v2/cluster/createKvmSearchEngineCluster", req, &createResp); err != nil {
+		return "", err
+	}
+	if createResp.Code != 0 || createResp.Result.ServiceGroupInstanceNo == 0 {
+		return "", fmt.Errorf("SES G3 create failed: code=%d message=%s", createResp.Code, createResp.Message)
+	}
+	return strconv.Itoa(int(createResp.Result.ServiceGroupInstanceNo)), nil
+}
+
+func sesServerSpecCodeFromProduct(productCode string) string {
+	specType := "s"
+	if strings.Contains(productCode, ".HICPU.") {
+		specType = "c"
+	}
+	if strings.Contains(productCode, ".HIMEM.") {
+		specType = "m"
+	}
+	cpu := regexp.MustCompile(`\.C0*([0-9]+)\.`).FindStringSubmatch(productCode)
+	if len(cpu) < 2 {
+		return "elst." + specType + "2-g3"
+	}
+	return "elst." + specType + cpu[1] + "-g3"
+}
