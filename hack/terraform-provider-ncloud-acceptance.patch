+func isCDSSG3Create(d *schema.ResourceData, managerNode, brokerNode map[string]interface{}) bool {
+	return strings.Contains(d.Get("os_image").(string), ".G003") ||
+		strings.Contains(managerNode["node_product_code"].(string), ".G003") ||
+		strings.Contains(brokerNode["node_product_code"].(string), ".G003")
+}
+
+func createCDSSG3Cluster(ctx context.Context, config *conn.ProviderConfig, d *schema.ResourceData, cmak, managerNode, brokerNode map[string]interface{}) (string, error) {
+	vpcNo := *GetInt32FromString(d.GetOk("vpc_no"))
+	managerSubnetNo := *GetInt32FromString(managerNode["subnet_no"], true)
+	brokerSubnetNo := *GetInt32FromString(brokerNode["subnet_no"], true)
+
+	managerSubnet, err := getCDSSG3Subnet(ctx, config, vpcNo, managerSubnetNo)
+	if err != nil {
+		return "", err
+	}
+	brokerSubnet, err := getCDSSG3Subnet(ctx, config, vpcNo, brokerSubnetNo)
+	if err != nil {
+		return "", err
+	}
+
+	req := map[string]any{
+		"clusterName":                                *StringPtrOrNil(d.GetOk("name")),
+		"kafkaVersionCode":                           *StringPtrOrNil(d.GetOk("kafka_version_code")),
+		"kafkaManagerUserName":                       *StringPtrOrNil(cmak["user_name"], true),
+		"kafkaManagerUserPassword":                   *StringPtrOrNil(cmak["user_password"], true),
+		"hypervisorCode":                             "KVM",
+		"generationCode":                             "G3",
+		"softwareProductCode":                        *StringPtrOrNil(d.GetOk("os_image")),
+		"vpcName":                                    managerSubnet.VpcName,
+		"vpcNo":                                      vpcNo,
+		"managerNodeSubnetName":                      managerSubnet.SubnetName,
+		"managerNodeSubnetNo":                        managerSubnetNo,
+		"managerNodeProductCode":                     *StringPtrOrNil(managerNode["node_product_code"], true),
+		"dataNodeSubnetName":                         brokerSubnet.SubnetName,
+		"dataNodeSubnetNo":                           brokerSubnetNo,
+		"dataNodeCount":                              *Int32PtrOrNil(brokerNode["node_count"], true),
+		"dataNodeProductCode":                        *StringPtrOrNil(brokerNode["node_product_code"], true),
+		"dataNodeStorageType2Code":                   "SSD",
+		"dataNodeStorageInfraResourceDetailTypeCode": "CB1",
+		"dataNodeStorageSize":                        *Int32PtrOrNil(brokerNode["storage_size"], true),
+		"configGroupNo":                              *GetInt32FromString(d.GetOk("config_group_no")),
+		"serverSpecCode":                             serverSpecCodeFromProduct("cdss", *StringPtrOrNil(brokerNode["node_product_code"], true)),
+	}
+
+	var createResp rawAPIResponse[bool]
+	if err := config.RawJSONRequest(ctx, "cdss", "POST", "/api/v1/cluster/createKvmCluster", req, &createResp); err != nil {
+		return "", err
+	}
+	if createResp.Code != 0 || !createResp.Result {
+		return "", fmt.Errorf("CDSS G3 create failed: code=%d message=%s", createResp.Code, createResp.Message)
+	}
+
+	return waitForCDSSG3ClusterID(ctx, config, *StringPtrOrNil(d.GetOk("name")))
+}
+
+type rawAPIResponse[T any] struct {
+	Code    int    `json:"code"`
+	Message string `json:"message"`
+	Result  T      `json:"result"`
+}
+
+type cdssG3Subnet struct {
+	SubnetName string `json:"subnetName"`
+	SubnetNo   int32  `json:"subnetNo"`
+	VpcName    string `json:"vpcName"`
+	VpcNo      int32  `json:"vpcNo"`
+	IsPublic   bool   `json:"isPublic"`
+}
+
+func getCDSSG3Subnet(ctx context.Context, config *conn.ProviderConfig, vpcNo, subnetNo int32) (*cdssG3Subnet, error) {
+	for _, isPrivate := range []bool{true, false} {
+		req := map[string]any{
+			"isPrivate":           isPrivate,
+			"softwareProductCode": "SW.VCDSS.OS.LNX64.ROCKY.08.G003",
+			"vpcNo":               vpcNo,
+		}
+		var resp rawAPIResponse[struct {
+			Content []cdssG3Subnet `json:"content"`
+		}]
+		if err := config.RawJSONRequest(ctx, "cdss", "POST", "/api/v1/cluster/getVpcAvailableSubnetList", req, &resp); err != nil {
+			return nil, err
+		}
+		for i := range resp.Result.Content {
+			if resp.Result.Content[i].SubnetNo == subnetNo {
+				return &resp.Result.Content[i], nil
+			}
+		}
+	}
+	return nil, fmt.Errorf("CDSS G3 subnet %d not found in VPC %d", subnetNo, vpcNo)
+}
+
+func waitForCDSSG3ClusterID(ctx context.Context, config *conn.ProviderConfig, name string) (string, error) {
+	stateConf := &resource.StateChangeConf{
+		Pending: []string{CDSSStatusNull},
+		Target:  []string{CDSSStatusCreating, CDSSStatusChanging, CDSSStatusRunning},
+		Refresh: func() (interface{}, string, error) {
+			var resp rawAPIResponse[struct {
+				AllowedClusters []struct {
+					ClusterName            string `json:"clusterName"`
+					ServiceGroupInstanceNo string `json:"serviceGroupInstanceNo"`
+					ServerStatus           string `json:"serverStatus"`
+				} `json:"allowedClusters"`
+			}]
+			if err := config.RawJSONRequest(ctx, "cdss", "POST", "/api/v1/cluster/getClusterInfoList", map[string]any{"pageNo": 0, "pageSize": 100}, &resp); err != nil {
+				return nil, "", err
+			}
+			for _, c := range resp.Result.AllowedClusters {
+				if c.ClusterName == name {
+					return c.ServiceGroupInstanceNo, c.ServerStatus, nil
+				}
+			}
+			return nil, CDSSStatusNull, nil
+		},
+		Timeout:    10 * time.Minute,
+		MinTimeout: 3 * time.Second,
+		Delay:      2 * time.Second,
+	}
+	result, err := stateConf.WaitForStateContext(ctx)
+	if err != nil {
+		return "", err
+	}
+	id, ok := result.(string)
+	if !ok || id == "" {
+		return "", fmt.Errorf("CDSS G3 cluster %s was created but no serviceGroupInstanceNo was found", name)
+	}
+	return id, nil
+}
+
+func serverSpecCodeFromProduct(service, productCode string) string {
+	prefix := service + "."
+	specType := "s"
+	if strings.Contains(productCode, ".HICPU.") {
+		specType = "c"
+	}
+	if strings.Contains(productCode, ".HIMEM.") {
+		specType = "m"
+	}
+	cpu := regexp.MustCompile(`\.C0*([0-9]+)\.`).FindStringSubmatch(productCode)
+	if len(cpu) < 2 {
+		return prefix + specType + "2-g3"
+	}
+	return prefix + specType + cpu[1] + "-g3"
+}
